# PlatformIO build output
.pio/

# Vendored LilyGO board support (re-clone into vendor/ — see project notes)
vendor/

# Editor / tooling
.vscode/
compile_commands.json

# macOS
.DS_Store

# Large regenerable map cache (refetch via tools/maps/build_map.py)
tools/maps/sf_overpass.json
*_overpass.json
tools/maps/__pycache__/

# Xcode user-specific state (the generated .xcodeproj itself is kept)
**/xcuserdata/
**/*.xcuserstate
companion-ios/DerivedData/

# Compiled preview-harness binary (rebuild via tools/preview/render_preview.sh)
tools/preview/preview

# FIT test-harness binary and the .fit files it emits (rebuild via
# tools/fit_test/run_fit_test.sh)
tools/fit_test/fit_test
tools/fit_test/ascent_test
tools/fit_test/out/

# Xcode archive / build output
companion-ios/build/

# Site images are generated at deploy time from tools/preview/out (see pages.yml).
# Uses docs/img/* rather than docs/img/ so the negations below work — git can't
# re-include a file whose parent *directory* is excluded.
docs/img/*
# ...except the brand icons, which are static assets, not generated screenshots.
!docs/img/favicon.png
!docs/img/favicon-32.png
!docs/img/apple-touch-icon.png
companion-ios/build-sim/
